{
  "expo": {
    "name": "GoCoursesLab",
    "slug": "GoCoursesLab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gocourseslab",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cyffrezynedd.gocourseslab",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Для быстрого входа по Face ID после сохранения логина (учебный сценарий ЛР4)."
      }
    },
    "android": {
      "package": "com.cyffrezynedd.gocourseslab",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Разрешите Face ID для входа в аккаунт (ЛР4)."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6c4c9c40-d99b-4de8-925f-cd4d11a41189"
      }
    }
  }
}
