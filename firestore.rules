rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /courses/{courseId} {
      allow read: if true;
      // Учебный проект: сид из `npm run seed:firestore`. Для прод: allow write: if false;
      allow create, update: if true;
      allow delete: if courseId == '99999';
    }
  }
}
