{
  "name": "gocourseslab",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "node ./scripts/expo-with-lan.mjs start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "node ./scripts/expo-with-lan.mjs start --android",
    "ios": "node ./scripts/expo-with-lan.mjs start --ios",
    "web": "node ./scripts/expo-with-lan.mjs start --web",
    "lint": "expo lint",
    "lab": "node ./scripts/run-lab.mjs",
    "seed:firestore": "node ./scripts/push-firestore-catalog.mjs",
    "seed:firestore:wait": "npx wait-on tcp:127.0.0.1:28765 && node ./scripts/push-firestore-catalog.mjs",
    "firebase:wizard": "node ./scripts/firebase-wizard.mjs",
    "firebase:check": "node ./scripts/check-firebase-env.mjs",
    "firebase:seed": "node ./scripts/push-firestore-catalog.mjs",
    "deploy:firestore-rules": "npx firebase deploy --only firestore:rules",
    "deploy:storage-rules": "npx firebase deploy --only storage",
    "emulator:firestore": "npx firebase emulators:start --only firestore,auth --project demo-gocourses-lab",
    "firewall:firestore": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows-firewall-firestore.ps1",
    "lan:ip": "node ./scripts/print-lan-ip.mjs",
    "env:sync": "node ./scripts/sync-env-lan.mjs",
    "test:new-course-add": "node ./scripts/firestore-test-new-course.mjs add",
    "test:new-course-remove": "node ./scripts/firestore-test-new-course.mjs remove"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@firebase/auth": "^1.13.1",
    "@firebase/firestore": "^4.14.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.13.0",
    "i18next": "^26.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "dotenv": "^16.6.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-tools": "^15.0.0",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.3"
  },
  "private": true
}
