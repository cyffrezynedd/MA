rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Учебный проект: клиент только читает каталог.
    // Один раз залейте данные: npm run seed:firestore (нужна временная запись — см. ниже).
    match /courses/{courseId} {
      allow read: if true;
      // После сида ВЕРНИТЕ allow write: if false; либо оставьте только для демо-проекта.
      allow write: if true;
    }
  }
}
