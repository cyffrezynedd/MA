rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Превью каталога: публичное чтение, запись только из консоли / Admin SDK.
    match /courses/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
